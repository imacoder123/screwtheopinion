# Environment variables for Node.js backend
# Database URL in the format: postgres://user:password@host:port/database
DATABASE_URL=postgres://username:password@localhost:5432/database_name

# JWT secret for signing tokens
JWT_SECRET=your_jwt_secret_key

# JWT expiry time in seconds (default 3600 = 1 hour)
JWT_EXPIRY=3600

# Refresh token expiry in seconds (default 604800 = 7 days)
JWT_REFRESH_EXPIRY=604800

# Server port
PORT=3000
